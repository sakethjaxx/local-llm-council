# LLM Council
# Copy this file to .env and fill in only the providers you plan to use.
# For Ollama-only local demos, all API keys below can stay empty.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-v1-...
GROQ_API_KEY=gsk_...

# Deployment / runtime flags
COUNCIL_HOST=127.0.0.1
COUNCIL_PORT=8765
COUNCIL_CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765
COUNCIL_API_KEY=  # set to protect all endpoints
COUNCIL_ALLOW_URL_FETCH=false  # set true to enable remote URL fetching (SSRF risk on non-localhost)
COUNCIL_MAX_UPLOAD_MB=20
COUNCIL_MAX_FILES=10
COUNCIL_ENABLE_PYTHON_TOOL=false
# Python REPL tool — requires Docker installed on host. Disabled by default.
# When enabled, LLM can execute arbitrary Python during phase-1. Advanced users only.
COUNCIL_SMART_PHASE_THRESHOLD=0.88  # MIN pairwise cosine sim above which Phase 2 is skipped
COUNCIL_METRICS_FILE=council_metrics.jsonl
COUNCIL_MAX_RECENT_RUNS=200
COUNCIL_BOOTSTRAP_LOCAL_MODELS=false

# Reliability / performance tuning
COUNCIL_LLM_TIMEOUT=180            # per-call LLM wall-clock ceiling (seconds)
COUNCIL_MAX_PARALLEL_MEMBERS=4     # max council members calling an LLM at once
COUNCIL_RELOAD=false              # dev auto-reload (drops active streams; off in prod)
